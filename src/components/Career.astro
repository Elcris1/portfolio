---
import { career } from '../data/career'
import { type Language } from '../i18n/translations'
import { getLangFromUrl, useTranslations } from '../i18n/utils'

const lang = getLangFromUrl(Astro.url) as Language
const t = useTranslations(lang)

const sortedCareer = [...career].sort((a, b) => {
  if (a.startYear !== b.startYear) return b.startYear - a.startYear
  return (b.endYear || 9999) - (a.endYear || 9999)
})

const education = sortedCareer.filter(item => item.type === 'education')
const work = sortedCareer.filter(item => item.type === 'work')
---

<section id="career" class="py-24 overflow-hidden">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="animate-on-scroll">
      <div class="flex items-center gap-4 mb-4">
        <h2 class="text-3xl font-bold">{t.career.title}</h2>
      </div>
      
      <div class="relative">
        <div class="absolute inset-0 flex justify-center">
          <div class="w-0.5 h-full bg-gradient-to-b from-indigo-500 via-violet-500 to-indigo-200/50 rounded-full"></div>
        </div>
        
        <div class="relative grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-16">
          <div class="space-y-16">
            <div class="flex items-center gap-3">
              <div class="px-4 py-2 rounded-full bg-gradient-to-r from-green-500 to-emerald-500 text-white font-semibold text-sm shadow-lg shadow-green-500/20">
                🎓 {t.career.education}
              </div>
              <div class="flex-1 h-0.5 bg-gradient-to-r from-green-500/50 to-transparent"></div>
            </div>
            
            {education.map((item, index) => (
              <div class="relative animate-on-scroll" style={`animation-delay: ${index * 150}ms`}>

                
                <div class="bg-white dark:bg-gray-900 p-5 rounded-2xl border border-gray-100 dark:border-gray-700 hover:shadow-xl hover:shadow-green-500/20 transition-all duration-300 group">
                  <div class="flex items-start justify-between mb-3">
                    <div>
                      <span class="inline-block px-3 py-1 rounded-full text-xs font-bold bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400 mb-2">{item.startYear} — {item.endYear || '...'}</span>
                      <h4 class="text-lg font-bold group-hover:text-green-600 dark:group-hover:text-green-400 transition-colors">{item.title[lang]}</h4>
                      <p class="text-sm text-indigo-600 dark:text-indigo-400 font-medium">{item.organization}</p>
                    </div>
                    <div class="w-10 h-10 rounded-xl bg-green-100 dark:bg-green-900/30 flex items-center justify-center flex-shrink-0">
                      <span class="text-xl">🎓</span>
                    </div>
                  </div>
                  <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed">{item.description[lang]}</p>
                </div>
              </div>
            ))}
          </div>
          
          <div class="space-y-16 md:mt-32">
            <div class="flex items-center gap-3">
              <div class="px-4 py-2 rounded-full bg-gradient-to-r from-blue-500 to-indigo-500 text-white font-semibold text-sm shadow-lg shadow-blue-500/20">
                💼 {t.career.work}
              </div>
              <div class="flex-1 h-0.5 bg-gradient-to-r from-blue-500/50 to-transparent"></div>
            </div>
            
            {work.map((item, index) => (
              <div class="relative animate-on-scroll" style={`animation-delay: ${index * 150 + 100}ms`}>
                
                <div class="bg-white dark:bg-gray-900 p-5 rounded-2xl border border-gray-100 dark:border-gray-700 hover:shadow-xl hover:shadow-blue-500/20 transition-all duration-300 group">
                  <div class="flex items-start justify-between mb-3">
                    <div>
                      <span class="inline-block px-3 py-1 rounded-full text-xs font-bold bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-400 mb-2">{item.startYear} — {item.endYear || '...'}</span>
                      <h4 class="text-lg font-bold group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors">{item.title[lang]}</h4>
                      <p class="text-sm text-indigo-600 dark:text-indigo-400 font-medium">{item.organization}</p>
                    </div>
                    <div class="w-10 h-10 rounded-xl bg-blue-100 dark:bg-blue-900/30 flex items-center justify-center flex-shrink-0">
                      <span class="text-xl">💼</span>
                    </div>
                  </div>
                  <p class="text-sm text-gray-600 dark:text-gray-400 leading-relaxed">{item.description[lang]}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
        
        <div class="absolute top-0 left-1/2 -translate-x-1/2 w-3 h-3 rounded-full bg-indigo-500 shadow-lg shadow-indigo-500/50 flex items-center justify-center">
          <span class="text-white text-xs">●</span>
        </div>
      </div>
    </div>
  </div>
</section>