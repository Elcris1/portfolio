---
import { config } from '../data/config'
import type { Language } from '../i18n/translations'
import { getLangFromUrl, getPath, useTranslations } from '../i18n/utils'

const lang = getLangFromUrl(Astro.url) as Language
const t = useTranslations(lang)
---

<section id="hero" class="min-h-screen flex items-center justify-center relative overflow-hidden pt-16">
  <div class="absolute inset-0">
    <div class="absolute top-20 left-1/4 w-72 h-72 bg-gradient-to-br from-indigo-500/10 to-transparent rounded-full blur-3xl"></div>
    <div class="absolute bottom-20 right-1/4 w-96 h-96 bg-gradient-to-tl from-violet-500/10 to-transparent rounded-full blur-3xl"></div>
  </div>
  
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center relative z-10">
    <div class="animate-on-scroll">
      
      <p class="text-lg text-gray-500 dark:text-gray-400 mb-2">
        {t.hero.greeting}
      </p>
      
      <h1 class="text-5xl sm:text-6xl lg:text-8xl font-bold tracking-tight mb-4">
        <span class="bg-gradient-to-r from-indigo-600 to-violet-600 bg-clip-text text-transparent">
          {config.name.split(' ')[0]}
        </span>
        <span class="text-gray-900 dark:text-white">
          {config.name.split(' ')[1] ? ' ' + config.name.split(' ')[1] : ''}
        </span>
      </h1>
      
      <div class="flex items-center justify-center gap-2 mb-6">
        <span class="px-4 py-2 rounded-full bg-gradient-to-r from-indigo-500/10 to-violet-500/10 border border-indigo-200 dark:border-indigo-800 text-sm font-medium">
          <span class="text-indigo-600 dark:text-indigo-400">▸</span> {config.title}
        </span>
      </div>
      
      <p class="text-xl text-gray-600 dark:text-gray-300 max-w-2xl mx-auto mb-10 leading-relaxed">
        {config.tagline[lang]}
      </p>
      
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
        <a
          href={getPath(lang, '#projects')}
          class="group px-8 py-4 rounded-xl font-medium text-white transition-all duration-300 bg-gradient-to-r from-indigo-600 to-violet-600 hover:shadow-lg hover:shadow-indigo-500/25 hover:-translate-y-0.5"
        >
          <span class="flex items-center gap-2">
            {t.hero.viewProjects}
            <svg class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </span>
        </a>
        <a
          href={getPath(lang, '#contact')}
          class="group px-8 py-4 rounded-xl font-medium transition-all duration-300 border-2 border-gray-200 dark:border-gray-700 hover:border-indigo-500 hover:bg-indigo-50 dark:hover:bg-indigo-900/20"
        >
          {t.hero.contact}
        </a>
      </div>
      
      <div class="mt-16 flex items-center justify-center gap-8 text-sm text-gray-400">
        <div class="flex items-center gap-2">
          <span class="w-2 h-2 rounded-full bg-green-500 animate-pulse"></span>
          <span>Open to work</span>
        </div>
        <div class="hidden sm:block w-16 h-px bg-gray-200 dark:bg-gray-700"></div>
        <span>{config.location[lang]}</span>
      </div>
    </div>
  </div>
  
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
    <svg class="w-6 h-6 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
    </svg>
  </div>
</section>