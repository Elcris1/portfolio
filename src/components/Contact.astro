---
import { config } from '../data/config'
import { getLangFromUrl, useTranslations } from '../i18n/utils'

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)

const socials = Object.entries(config.social).filter(([_, url]) => url)
---

<section id="contact" class="py-24 relative overflow-hidden">
  <div class="absolute inset-0 opacity-30">
    <div class="absolute top-0 left-1/4 w-72 h-72 bg-gradient-to-br from-indigo-500/20 to-transparent rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 right-1/4 w-96 h-96 bg-gradient-to-tl from-violet-500/20 to-transparent rounded-full blur-3xl"></div>
  </div>
  
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
    <div class="animate-on-scroll text-center mb-16">
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-gradient-to-r from-indigo-500/10 to-violet-500/10 border border-indigo-200 dark:border-indigo-800 mb-6">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-green-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-green-500"></span>
        </span>
        <span class="text-sm font-medium text-indigo-600 dark:text-indigo-400">Available for new opportunities</span>
      </div>
      
      <h2 class="text-4xl md:text-5xl font-bold mb-4">
        Let's <span class="bg-gradient-to-r from-indigo-600 to-violet-600 bg-clip-text text-transparent">talk</span>
      </h2>
      <p class="text-lg text-gray-600 dark:text-gray-400 max-w-xl mx-auto">
        {t.contact.subtitle}
      </p>
    </div>
    
    <div class="animate-on-scroll" style="animation-delay: 100ms">
      <div class="bg-white dark:bg-gray-900 rounded-3xl p-8 md:p-12 border border-gray-100 dark:border-gray-800 shadow-2xl shadow-indigo-500/5">
        <div class="flex flex-col md:flex-row items-center justify-center gap-8 mb-10">
          <div class="text-center">
            
            <p class="text-sm text-gray-500 dark:text-gray-400 mb-2">Email</p>
            <a
              href={`mailto:${config.email}`}
              class="text-xl font-medium text-gray-900 dark:text-white hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors"
            >
              {config.email}
            </a>
          </div>
          
          
        </div>
        
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
          <button
            id="copy-email"
            data-email={config.email}
            class="group px-8 py-4 rounded-xl font-medium bg-gradient-to-r from-indigo-600 to-violet-600 text-white hover:shadow-lg hover:shadow-indigo-500/30 transition-all duration-300 hover:-translate-y-0.5"
          >
            <span class="flex items-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
              </svg>
              <span id="copy-text">{t.contact.copyEmail}</span>
            </span>
          </button>
          
          <a
            href={`mailto:${config.email}`}
            class="group px-8 py-4 rounded-xl font-medium border-2 border-gray-200 dark:border-gray-700 hover:border-indigo-500 dark:hover:border-indigo-400 transition-all duration-300 hover:-translate-y-0.5"
          >
            <span class="flex items-center gap-2">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              Send a message
            </span>
          </a>
        </div>
      </div>
    </div>
    
    <div class="animate-on-scroll mt-12" style="animation-delay: 200ms">
      <p class="text-center text-sm text-gray-500 dark:text-gray-400 mb-6">Or find me on social media</p>
      
      <div class="flex items-center justify-center gap-4">
        {socials.map(([platform, url]) => (
          <a
            href={url}
            target="_blank"
            rel="noopener noreferrer"
            class="group relative p-4 rounded-2xl bg-white/50 dark:bg-gray-900/50 backdrop-blur-sm border border-gray-200 dark:border-gray-800 hover:border-indigo-500 dark:hover:border-indigo-400 transition-all duration-300 hover:shadow-xl hover:shadow-indigo-500/20 hover:-translate-y-1"
            aria-label={platform}
          >
            {platform === 'github' && (
              <svg class="w-6 h-6 transition-colors duration-300 group-hover:fill-[#333] dark:group-hover:fill-[#8b949e]" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
              </svg>
            )}
            {platform === 'linkedin' && (
              <svg class="w-6 h-6 text-gray-600 dark:text-gray-400 transition-colors duration-300 group-hover:text-[#0077B5]" fill="currentColor" viewBox="0 0 24 24">
                <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
              </svg>
            )}
            {platform === 'twitter' && (
              <svg class="w-6 h-6 text-gray-600 dark:text-gray-400 transition-colors duration-300 group-hover:text-gray-900 dark:group-hover:text-white" fill="currentColor" viewBox="0 0 24 24">
                <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
              </svg>
            )}
          </a>
        ))}
      </div>
    </div>
  </div>
</section>

<script define:vars={{ copyText: t.contact.copyEmail, copiedText: t.contact.copied }}>
  const copyButton = document.getElementById('copy-email')
  const copyTextEl = document.getElementById('copy-text')
  
  if (copyButton && copyTextEl) {
    copyButton.addEventListener('click', async () => {
      await navigator.clipboard.writeText(copyButton.dataset.email || '')
      copyTextEl.textContent = copiedText
      copyButton.classList.remove('from-indigo-600', 'to-violet-600')
      copyButton.classList.add('from-green-500', 'to-emerald-500')
      
      setTimeout(() => {
        copyTextEl.textContent = copyText
        copyButton.classList.remove('from-green-500', 'to-emerald-500')
        copyButton.classList.add('from-indigo-600', 'to-violet-600')
      }, 2000)
    })
  }
</script>