---
import { config } from '../data/config'
import type { Language } from '../i18n/translations'
import { projects, type Project } from '../data/projects'
import { getLangFromUrl, useTranslations } from '../i18n/utils'

const lang = getLangFromUrl(Astro.url) as Language
const t = useTranslations(lang)

const sortedProjects = [...projects].sort((a, b) => Number(b.featured) - Number(a.featured))
---

<section id="projects" class="py-24 bg-gray-50 dark:bg-gray-900">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="animate-on-scroll">
      <div class="flex items-center gap-4 mb-4">
        <span class="text-4xl">🚀</span>
        <h2 class="text-3xl font-bold">{t.projects.title}</h2>
      </div>
      <p class="text-gray-600 dark:text-gray-400 mb-12 ml-12">{t.projects.subtitle}</p>
      {sortedProjects.length === 0 ? (
        <h3 class="text-xl font-semibold mb-6">{t.todo.section}</h3>
      ) : (
          <div class="grid md:grid-cols-2 gap-6">
          {sortedProjects.map((project, index) => (
            <article
              data-project={JSON.stringify(project)}
              class="project-card group bg-white dark:bg-gray-800 rounded-2xl border border-gray-100 dark:border-gray-700 hover:shadow-xl hover:shadow-indigo-500/10 transition-all duration-300 animate-on-scroll overflow-hidden cursor-pointer"
              style={`animation-delay: ${index * 100}ms`}
            >
              {project.featured && (
                <div class="absolute top-0 right-0 w-24 h-24 bg-gradient-to-bl from-indigo-500/10 to-transparent rounded-bl-full"></div>
              )}
              
              <div class="relative aspect-video overflow-hidden bg-gradient-to-br from-indigo-500/20 to-violet-500/20 dark:from-indigo-900/30 dark:to-violet-900/30">
                {project.images && project.images.length > 0 ? (
                  <img 
                    src={project.images[0].url} 
                    alt={project.images[0].alt[lang]}
                    class="w-full h-full object-contain"
                    onerror="this.style.display='none'; this.parentElement.querySelector('.placeholder').style.display='flex';"
                  />
                ) : null}
                <div class="placeholder absolute inset-0 flex items-center justify-center">
                  <div class="w-16 h-16 rounded-2xl bg-gradient-to-br from-indigo-500 to-violet-500 flex items-center justify-center text-2xl font-bold text-white shadow-lg">
                    {project.title[lang][0]}
                  </div>
                </div>
                <div class="absolute inset-0 bg-gradient-to-t from-black/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity flex items-end justify-center pb-4">
                  <span class="text-white text-sm font-medium flex items-center gap-1">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                    </svg>
                    View details
                  </span>
                </div>
                {project.images && project.images.length > 1 && (
                  <div class="absolute top-2 right-2 px-2 py-1 rounded-full bg-black/50 text-white text-xs font-medium">
                    +{project.images.length - 1}
                  </div>
                )}
              </div>
              
              <div class="p-6">
                <div class="flex items-start justify-between mb-3">
                  <h3 class="text-xl font-semibold">{project.title[lang]}</h3>
                  {project.private && (
                    <span class="inline-flex items-center gap-1 px-2 py-1 rounded-full text-xs font-medium bg-amber-100 dark:bg-amber-900/30 text-amber-700 dark:text-amber-400">
                      <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
                      </svg>
                      Private
                    </span>
                  )}
                  {project.featured && !project.private && (
                    <span class="inline-flex items-center gap-1 text-xs font-medium text-indigo-600 dark:text-indigo-400">
                      <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                      </svg>
                      {t.projects.featured}
                    </span>
                  )}
                </div>
                
                <p class="text-gray-600 dark:text-gray-400 mb-4">{project.shortDescription[lang]}</p>
                
                <div class="flex flex-wrap gap-2 mb-4">
                  {project.tags.map((tag) => (
                    <span class="px-3 py-1 rounded-full text-xs font-medium bg-indigo-50 dark:bg-indigo-900/20 text-indigo-600 dark:text-indigo-300">
                      {tag}
                    </span>
                  ))}
                </div>
                
                <div class="flex items-center gap-4 text-sm">
                  {project.repo && (
                    <a
                      href={project.repo}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center gap-2 text-gray-600 dark:text-gray-400 hover:text-indigo-600 dark:hover:text-indigo-400 transition-colors"
                      onclick="event.stopPropagation()"
                    >
                      <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                      </svg>
                      {t.projects.repo}
                    </a>
                  )}
                  {project.demo && (
                    <a
                      href={project.demo}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center gap-2 px-3 py-1.5 rounded-lg bg-gray-100 dark:bg-gray-700 hover:bg-indigo-100 dark:hover:bg-indigo-900/30 transition-colors"
                      onclick="event.stopPropagation()"
                    >
                      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                      </svg>
                      {t.projects.demo}
                    </a>
                  )}
                  {!project.repo && !project.demo && (
                    <span class="text-gray-400 text-sm">No public links</span>
                  )}
                </div>
              </div>
            </article>
          ))}
        </div>
      )}  
    </div>
  </div>
</section>

<div id="project-modal" class="fixed inset-0 z-50 hidden">
  <div class="absolute inset-0 bg-black/80 backdrop-blur-sm" id="modal-backdrop"></div>
  <div class="absolute inset-4 md:inset-8 lg:inset-16 bg-white dark:bg-gray-900 rounded-2xl overflow-hidden shadow-2xl flex flex-col">
    <div class="flex items-center justify-between p-4 border-b border-gray-100 dark:border-gray-800">
      <h3 id="modal-title" class="text-xl font-bold"></h3>
      <button id="modal-close" class="p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800 transition-colors">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>
    <div class="flex-1 overflow-y-auto p-6" id="modal-content"></div>
  </div>
</div>

<div id="lightbox" class="fixed inset-0 z-[60] hidden bg-black/95 flex flex-col">
  <div class="flex items-center justify-center p-4" id="lightbox-content" style="flex: 1 1 auto; min-height: 0;">
    <img id="lightbox-img" src="" alt="" class="max-w-full max-h-full object-contain" style="max-height: calc(100vh - 8rem);" />
  </div>
  <p id="lightbox-caption" class="px-6 py-4 text-center text-white bg-black/50 text-sm" style="flex: 0 0 auto;"></p>
  <button id="lightbox-close" class="absolute top-4 right-4 p-2 text-white/70 hover:text-white transition-colors z-10">
    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
    </svg>
  </button>
  <button id="lightbox-prev" class="absolute left-4 top-1/2 -translate-y-1/2 p-2 text-white/70 hover:text-white transition-colors z-10">
    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
    </svg>
  </button>
  <button id="lightbox-next" class="absolute right-4 top-1/2 -translate-y-1/2 p-2 text-white/70 hover:text-white transition-colors z-10">
    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
    </svg>
  </button>
</div>

<script define:vars={{ translations: { description: { es: "Descripción", en: "Description", ca: "Descripció" }, technologies: { es: "Tecnologías", en: "Technologies", ca: "Tecnologies" }, gallery: { es: "Galería", en: "Gallery", ca: "Galeria" }, noImages: { es: "No hay imágenes disponibles", en: "No images available", ca: "No hi ha imatges disponibles" } } }}>
  const lang = window.location.pathname.split('/')[1] || 'es';
  const modal = document.getElementById('project-modal');
  const modalTitle = document.getElementById('modal-title');
  const modalContent = document.getElementById('modal-content');
  const modalClose = document.getElementById('modal-close');
  const modalBackdrop = document.getElementById('modal-backdrop');
  const lightbox = document.getElementById('lightbox');
  const lightboxImg = document.getElementById('lightbox-img');
  const lightboxCaption = document.getElementById('lightbox-caption');
  const lightboxClose = document.getElementById('lightbox-close');
  const lightboxPrev = document.getElementById('lightbox-prev');
  const lightboxNext = document.getElementById('lightbox-next');

  let currentImages = [];
  let currentIndex = 0;

  function openLightbox() {
    const mainImg = document.getElementById('gallery-main-img');
    if (!mainImg) return;
    const imagesData = JSON.parse(mainImg.dataset.allImages || '[]');
    currentImages = imagesData;
    const allThumbs = document.querySelectorAll('.gallery-thumb');
    const activeThumb = document.querySelector('.gallery-thumb.border-indigo-500');
    currentIndex = activeThumb ? Array.from(allThumbs).indexOf(activeThumb) : 0;
    showLightboxImage();
    lightbox.classList.remove('hidden');
    lightbox.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }

  function showLightboxImage() {
    lightboxImg.src = currentImages[currentIndex].url;
    lightboxImg.alt = currentImages[currentIndex].alt[lang];
    lightboxCaption.textContent = currentImages[currentIndex].alt[lang];
  }

  function closeLightbox() {
    lightbox.classList.add('hidden');
    lightbox.classList.remove('flex');
  }

  lightboxPrev.addEventListener('click', () => {
    currentIndex = (currentIndex - 1 + currentImages.length) % currentImages.length;
    showLightboxImage(); 
  });

  lightboxNext.addEventListener('click', () => {
    currentIndex = (currentIndex + 1) % currentImages.length;
    showLightboxImage(); 
  });


  lightboxClose.addEventListener('click', closeLightbox);
  lightbox.addEventListener('click', (e) => { if (e.target === lightbox) closeLightbox(); });
  document.addEventListener('keydown', (e) => {
    if (!lightbox.classList.contains('hidden')) {
      if (e.key === 'Escape') closeLightbox();
      if (e.key === 'ArrowLeft' ) { 
        currentIndex = (currentIndex - 1 + currentImages.length) % currentImages.length;
        showLightboxImage(); 
      }
      if (e.key === 'ArrowRight') { 
        currentIndex = (currentIndex + 1) % currentImages.length;
        showLightboxImage(); 
      }
    }
  });

  document.querySelectorAll('.project-card').forEach(card => {
    card.addEventListener('click', () => {
      const project = JSON.parse(card.dataset.project);
      
      modalTitle.textContent = project.title[lang];
      
      let html = '';
      
      if (project.description && project.description[lang]) {
        const descParagraphs = project.description[lang].split('\n\n');
        html += `<div class="mb-8">
          <h4 class="text-lg font-semibold mb-4 flex items-center gap-2">
            <span>📝</span> ${translations.description[lang]}
          </h4>
          ${descParagraphs.map(p => `<p class="text-gray-600 dark:text-gray-400 mb-4 leading-relaxed">${p}</p>`).join('')}
        </div>`;
      }
      
      html += `<div class="mb-8">
        <h4 class="text-lg font-semibold mb-4 flex items-center gap-2">
          <span>⚡</span> ${translations.technologies[lang]}
        </h4>
        <div class="flex flex-wrap gap-2">
          ${project.tags.map(tag => `<span class="px-4 py-2 rounded-lg text-sm font-medium bg-indigo-100 dark:bg-indigo-900/30 text-indigo-600 dark:text-indigo-300">${tag}</span>`).join('')}
        </div>
      </div>`;
      
      if (project.images && project.images.length > 0) {
        html += `<div>
          <h4 class="text-lg font-semibold mb-4 flex items-center gap-2">
            <span>🖼️</span> ${translations.gallery[lang]}
          </h4>
          <div class="flex flex-col items-center gap-4">
            <p class="text-gray-600 dark:text-gray-400 mb-4 leading-relaxed" id="image-caption"></p>
            <div class="relative w-full max-w-2xl aspect-video rounded-xl overflow-hidden bg-gray-100 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 group cursor-zoom-in" id="gallery-main">
              <img id="gallery-main-img" data-all-images='${JSON.stringify(project.images)}' src="${project.images[0].url}" alt="${project.images[0].alt[lang]}" class="w-full h-full object-contain" />
              ${project.images.length > 1 ? `
              <button id="gallery-prev" class="absolute left-2 top-1/2 -translate-y-1/2 p-2 rounded-full bg-black/50 text-white/70 hover:text-white transition-colors opacity-0 group-hover:opacity-100">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
                </svg>
              </button>
              <button id="gallery-next" class="absolute right-2 top-1/2 -translate-y-1/2 p-2 rounded-full bg-black/50 text-white/70 hover:text-white transition-colors opacity-0 group-hover:opacity-100">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
                </svg>
              </button>
              ` : ''}
            </div>
            <div class="flex gap-2 overflow-x-auto pb-2 w-full max-w-2xl justify-center" id="gallery-thumbs">
              ${project.images.map((img, i) => `
                <button class="gallery-thumb flex-shrink-0 w-16 h-12 rounded-lg overflow-hidden border-2 transition-all ${i === 0 ? 'border-indigo-500 opacity-100' : 'border-transparent opacity-60 hover:opacity-80'}" data-index="${i}">
                  <img src="${img.url}" alt="${img.alt[lang]}" class="w-full h-full object-contain" />
                </button>
              `).join('')}
            </div>
          </div>
        </div>`;
      } else {
        html += `<div class="text-center py-8 text-gray-400">
          <span class="text-4xl mb-2 block">📭</span>
          ${translations.noImages[lang]}
        </div>`;
      }
      
      modalContent.innerHTML = html;
      modal.classList.remove('hidden');
      document.body.style.overflow = 'hidden';

      const galleryMainImg = document.getElementById('gallery-main-img');
      if (galleryMainImg) {
        const imagesData = JSON.parse(galleryMainImg.dataset.allImages || '[]');
        const thumbs = document.querySelectorAll('.gallery-thumb');
        const prevBtn = document.getElementById('gallery-prev');
        const nextBtn = document.getElementById('gallery-next');
        const imageCaption = document.getElementById('image-caption');
        galleryMainImg.addEventListener('click', () => openLightbox(galleryMainImg));
        function setGalleryImage(idx) {
          currentIndex = idx;
          const imgData = imagesData[idx];
          galleryMainImg.src = imgData.url;
          galleryMainImg.alt = imgData.alt?.[lang] || '';
          if (imageCaption) {
            const altText = imgData.alt?.[lang] || `Image ${idx + 1} of ${imagesData.length}`;
            imageCaption.textContent = altText;
          }
          thumbs.forEach((t, i) => {
            t.classList.toggle('border-indigo-500', i === idx);
            t.classList.toggle('opacity-100', i === idx);
            t.classList.toggle('border-transparent', i !== idx);
            t.classList.toggle('opacity-60', i !== idx);
          });
        }
        thumbs.forEach(t => t.addEventListener('click', () => setGalleryImage(parseInt(t.dataset.index))));
        if (prevBtn) prevBtn.addEventListener('click', e => { e.stopPropagation(); setGalleryImage((currentIndex - 1 + imagesData.length) % imagesData.length); });
        if (nextBtn) nextBtn.addEventListener('click', e => { e.stopPropagation(); setGalleryImage((currentIndex + 1) % imagesData.length); });
        setGalleryImage(0);
      }
    });
  });
  
  function closeModal() {
    modal.classList.add('hidden');
    document.body.style.overflow = '';
    closeLightbox();
  }
  
  modalClose.addEventListener('click', closeModal);
  modalBackdrop.addEventListener('click', closeModal);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !modal.classList.contains('hidden')) {
      closeModal();
    }
  });

  window.openLightbox = openLightbox;
</script>